# ==========================================================
# medical-triage-agent-ai-poc/.env.example
# ==========================================================

# ==========================================================
# APPLICATION
# ==========================================================

APP_ENV=development

LOG_LEVEL=INFO

# ==========================================================
# SECURITY
# ==========================================================

SECRET_KEY=CHANGE_ME

JWT_ALGORITHM=HS256

ACCESS_TOKEN_EXPIRE_MINUTES=60

# ==========================================================
# RATE LIMITING
# ==========================================================

RATE_LIMIT_REQUESTS=100

RATE_LIMIT_WINDOW_SECONDS=60

# ==========================================================
# HUGGING FACE
# ==========================================================

HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

HF_MODEL_ID=your-org/qwen3-medical-triage

HF_SPACE_API_URL=https://your-space-api.hf.space

# ==========================================================
# MODAL
# ==========================================================

MODAL_TOKEN_ID=ak-xxxxxxxxxxxxxxxxxxxxxxxx

MODAL_TOKEN_SECRET=as-xxxxxxxxxxxxxxxxxxxxxxxx

MODAL_ENDPOINT_URL=https://your-modal-endpoint.modal.run

# ==========================================================
# MLFLOW
# ==========================================================

MLFLOW_TRACKING_URI=http://mlflow:5000

# ==========================================================
# WANDB
# ==========================================================

WANDB_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxx

WANDB_PROJECT=medical-triage-agent-ai-poc

# ==========================================================
# FRONTEND
# ==========================================================

API_BASE_URL=http://backend:8000

# ==========================================================
# MONITORING
# ==========================================================

PROMETHEUS_ENABLED=true
