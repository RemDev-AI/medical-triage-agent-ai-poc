# medical-triage-agent-ai-poc/backend/app/deployment/huggingface/hf_space_backend.env

HF_SPACE=true

ENVIRONMENT=production

MODEL_PROVIDER=huggingface

HF_MODEL_REPOSITORY=RemDev-AI/medical-triage-agent-ai-poc-models

HF_TOKEN=

# DEVICE=auto
DEVICE=cpu

# USE_VLLM=true
USE_VLLM=false

LOAD_IN_4BIT=false
# LOAD_IN_8BIT=true
LOAD_IN_8BIT=false

MAX_INPUT_TOKENS=2048
MAX_OUTPUT_TOKENS=512

API_WORKERS=1

ENABLE_MONITORING=true

ENABLE_REQUEST_TRACKING=true
