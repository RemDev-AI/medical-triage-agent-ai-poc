# ==========================================================
# medical-triage-agent-ai-poc/backend/Dockerfile.hf
# Hugging Face Space API Container
#
# IMPORTANT : build avec la RACINE du dépôt comme contexte,
# cf. backend/Dockerfile pour l'explication complète.
# ==========================================================

FROM python:3.11-slim

# ==========================================================
# ENVIRONMENT
# ==========================================================

ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1

ENV APP_HOME=/app

# Hugging Face / Modal
ENV HF_HOME=/tmp/huggingface

WORKDIR ${APP_HOME}

# ==========================================================
# SYSTEM DEPENDENCIES
# ==========================================================

RUN apt-get update && apt-get install -y \
    build-essential \
    gcc \
    g++ \
    curl \
    git \
    && rm -rf /var/lib/apt/lists/*

# ==========================================================
# PYTHON DEPENDENCIES
# ==========================================================
COPY requirements.txt ./requirements.txt
RUN pip install --upgrade pip
RUN pip install --no-cache-dir -r requirements.txt

# ==========================================================
# APPLICATION
# ==========================================================
COPY . ./

# ==========================================================
# HUGGING FACE SPACES
# ==========================================================

ENV PORT=7860

EXPOSE 7860

# ==========================================================
# HEALTHCHECK
# ==========================================================

HEALTHCHECK --interval=30s \
            --timeout=10s \
            --start-period=30s \
            --retries=5 \
            CMD curl -f http://localhost:${PORT}/health || exit 1

# ==========================================================
# STARTUP
# ==========================================================
CMD ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "7860"]
